APP_ENV=dev
PORT=8000

# Weaviate vector database (self-hosted)
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=                    # Optional, leave empty for local dev
WEAVIATE_GRPC_PORT=50051

# Embeddings & Reranker
EMB_MODEL=intfloat/multilingual-e5-base       # tốt cho tiếng Việt
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2   # tuỳ chọn (có thể để trống)

# Legacy storage dir (not used with Weaviate)
STORAGE_DIR=./storage

# Logging
LOG_LEVEL=INFO
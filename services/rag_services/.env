APP_ENV=dev
PORT=8000

# Vector store backend
VECTOR_BACKEND=weaviate      # faiss, chroma, hoặc weaviate
STORAGE_DIR=./storage        # nơi lưu FAISS index + docstore (nếu dùng local)

# Weaviate Configuration (Local)
WEAVIATE_URL=http://localhost:8090
WEAVIATE_API_KEY=
WEAVIATE_CLASS_NAME=VietnameseDocumentV3  # Class name - matches actual collection with data
WEAVIATE_USE_CLOUD=false             # true = cloud, false = local
WEAVIATE_GRPC_PORT=50051

# Embeddings & Reranker
EMB_MODEL=intfloat/multilingual-e5-base       # tốt cho tiếng Việt
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2   # tuỳ chọn (có thể để trống)

# Reranking configuration
USE_RERANKING=true   # Tạm tắt - model returning 0.0 scores
RERANK_BATCH_SIZE=16
RERANK_MAX_LENGTH=512
VIETNAMESE_RERANK_MODEL= bkai-foundation-models/vietnamese-cross-encoder

# Chroma (nếu dùng)
#CHROMA_PERSIST_DIR=./storage/chroma

# Logging
LOG_LEVEL=INFO

# =============================================================================
# LLM Configuration - OPENROUTER ONLY (không dùng OpenAI/Gemini trực tiếp)
# =============================================================================
# Tất cả LLM calls (relation extraction, entity extraction, RAG, etc.)
# đều đi qua OpenRouter API - https://openrouter.ai
#
# Get API key from: https://openrouter.ai/keys (Free $1 credit)
# =============================================================================

LLM_PROVIDER=openrouter
LLM_MODEL=
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2000

# OpenRouter API Key (REQUIRED - điền vào đây)
# Format: sk-or-v1-xxxxxxxxxxxxx
OPENAI_API_KEY=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

# OpenRouter API endpoint (DO NOT CHANGE)
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# =============================================================================
# 3-TIER EXTRACTION STRATEGY
# =============================================================================
# Cost-optimized model selection per extraction tier
# Total cost: $0.20 per 100-page doc (vs $15 with Claude Sonnet = 98.7% savings)
# =============================================================================

# Tier 2: Entity Extraction (Grok 4.1 Fast - $0.50/1M input, same as Tier 3)
TIER2_MODEL_ID=x-ai/grok-4.1-fast
TIER2_TEMPERATURE=0.1
TIER2_MAX_TOKENS=2048

# Tier 3: Complex Rules (Grok 4.1 Fast - $0.50/1M input)
TIER3_MODEL_ID=x-ai/grok-4.1-fast
TIER3_TEMPERATURE=0.0
TIER3_MAX_TOKENS=4096


# Neo4j Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=uitchatbot
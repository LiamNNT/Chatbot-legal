APP_ENV=dev
PORT=8000

# Weaviate vector database (self-hosted)
WEAVIATE_URL=http://localhost:8090
WEAVIATE_API_KEY=                    # Optional, leave empty for local dev
WEAVIATE_GRPC_PORT=50051

# Embeddings & Reranker
EMB_MODEL=intfloat/multilingual-e5-base       # Good for Vietnamese
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2   # Optional

# Reranking configuration
USE_RERANKING=true
RERANK_BATCH_SIZE=16
RERANK_MAX_LENGTH=512
RERANK_TOP_K=20
VIETNAMESE_RERANK_MODEL=              # Optional Vietnamese-specific model

# Legacy storage dir (not used with Weaviate)
STORAGE_DIR=./storage

# OpenSearch for keyword/BM25 search
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_INDEX=rag_documents
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false

# Hybrid search configuration
USE_HYBRID_SEARCH=true
BM25_WEIGHT=0.5
VECTOR_WEIGHT=0.5
RRF_RANK_CONSTANT=60

# LlamaIndex Integration (NEW - Recommended)
# Set to "true" to use LlamaIndex-based search service
# Set to "false" to use legacy manual search service
USE_LLAMAINDEX=true

# Logging
LOG_LEVEL=INFO

# Neo4j Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=uitchatbot

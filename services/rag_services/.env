APP_ENV=dev
PORT=8000

# Vector store backend
VECTOR_BACKEND=weaviate      # faiss, chroma, hoặc weaviate
STORAGE_DIR=./storage        # nơi lưu FAISS index + docstore (nếu dùng local)

# Weaviate Configuration (Local)
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=
WEAVIATE_CLASS_NAME=VietnameseDocument  # Class name - FIXED to match actual collection
WEAVIATE_USE_CLOUD=false             # true = cloud, false = local
WEAVIATE_GRPC_PORT=50051

# Embeddings & Reranker
EMB_MODEL=intfloat/multilingual-e5-base       # tốt cho tiếng Việt
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2   # tuỳ chọn (có thể để trống)

# Chroma (nếu dùng)
CHROMA_PERSIST_DIR=./storage/chroma

# Logging
LOG_LEVEL=INFO
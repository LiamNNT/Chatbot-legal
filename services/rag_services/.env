# =============================================================================
# RAG SERVICES CONFIGURATION
# =============================================================================
# This .env file configures the RAG (Retrieval-Augmented Generation) service
# Including: Vector Store, Embeddings, Reranking, LLM, and extraction models
# =============================================================================

# -----------------------------------------------------------------------------
# 1. SERVER
# -----------------------------------------------------------------------------
APP_ENV=dev
PORT=8000
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# 1.1 LLAMAINDEX INTEGRATION (NEW - Recommended)
# -----------------------------------------------------------------------------
# Set to "true" to use LlamaIndex-based search service (recommended)
# Set to "false" to use legacy manual search service
USE_LLAMAINDEX=true

# Set to "true" to use LlamaIndex-based extraction (LlamaParse + PropertyGraphIndex)
# Set to "false" to use legacy hybrid extraction (VLM + LLM 2-stage)
USE_LLAMAINDEX_EXTRACTION=true

# LlamaParse API Key (required for LlamaIndex extraction)
# Get your key from: https://cloud.llamaindex.ai/
LLAMA_CLOUD_API_KEY=llx-zmvkhaeqiEKQWTxYlcZHtVqc8awCr4iXXpBS9KrNvexWmPSx

# LlamaParse Advanced Settings
# Enable GPT-4o mode for complex documents (requires OpenAI API key)
# Note: GPT-4o mode only works with parse_mode="parse_page_with_lvm"
LLAMA_PARSE_GPT4O_MODE=false
# Extract tables as JSON in addition to Markdown
LLAMA_PARSE_TABLES_JSON=false

# -----------------------------------------------------------------------------
# 2. VECTOR STORE (Weaviate)
# -----------------------------------------------------------------------------
VECTOR_BACKEND=weaviate
WEAVIATE_URL=http://localhost:8090
WEAVIATE_CLASS_NAME=VietnameseDocumentV3
WEAVIATE_USE_CLOUD=false
WEAVIATE_GRPC_PORT=50051
WEAVIATE_API_KEY=

# -----------------------------------------------------------------------------
# 3. EMBEDDINGS & RERANKING
# -----------------------------------------------------------------------------
EMB_MODEL=intfloat/multilingual-e5-base
USE_RERANKING=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_BATCH_SIZE=16
RERANK_MAX_LENGTH=512
# Vietnamese rerank model (disabled - model not available on HuggingFace)
# VIETNAMESE_RERANK_MODEL=bkai-foundation-models/vietnamese-cross-encoder
VIETNAMESE_RERANK_MODEL=

# -----------------------------------------------------------------------------
# 4. OPENROUTER API (LLM Provider)
# -----------------------------------------------------------------------------
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2000

OPENROUTER_API_KEY=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
OPENAI_API_KEY=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
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# -----------------------------------------------------------------------------
# 5. NEO4J GRAPH DATABASE
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=uitchatbot

# -----------------------------------------------------------------------------
# 6. EXTRACTION MODELS (3-Tier Strategy)
# -----------------------------------------------------------------------------
# VLM Model for document structure extraction (Tier 1)
VLM_MODEL=openai/gpt-4o-mini

# Entity Extraction Model (Tier 2)
TIER2_MODEL_ID=x-ai/grok-4.1-fast
TIER2_TEMPERATURE=0.1
TIER2_MAX_TOKENS=2048

# Complex Rules Extraction Model (Tier 3)
TIER3_MODEL_ID=x-ai/grok-4.1-fast
TIER3_TEMPERATURE=0.0
TIER3_MAX_TOKENS=4096

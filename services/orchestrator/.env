# Environment variables for orchestrator service

# OpenRouter Configuration
OPENROUTER_API_KEY=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
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-3.5-turbo
OPENROUTER_TIMEOUT=none
OPENROUTER_MAX_RETRIES=3

# RAG Service Configuration
RAG_SERVICE_URL=http://localhost:8000
RAG_SERVICE_TIMEOUT=none
RAG_SERVICE_MAX_RETRIES=3

# Default System Prompt (optional)
DEFAULT_SYSTEM_PROMPT=Bạn là một trợ lý AI thông minh và hữu ích cho Chatbot-UIT. Hãy trả lời câu hỏi một cách chính xác và hữu ích bằng tiếng Việt.

# Server Configuration
HOST=0.0.0.0
PORT=8001

# Logging - Set to DEBUG to see full retrieval flow details
LOG_LEVEL=DEBUG

# =============================================================================
# OPTIMIZED 3-AGENT PIPELINE (40% cost savings)
# =============================================================================
# Pipeline: SmartPlanner → AnswerAgent → ResponseFormatter
# Benefits: ~40% fewer LLM calls, ~25% token reduction

# Agent Configuration File
AGENT_CONFIG_FILE=agents_config_optimized.yaml

# =============================================================================
# IRCoT (Interleaving Retrieval with Chain-of-Thought) Configuration
# =============================================================================
# Enable IRCoT for complex multi-hop questions
IRCOT_ENABLED=true
IRCOT_MAX_ITERATIONS=3
IRCOT_COMPLEXITY_THRESHOLD=6.5
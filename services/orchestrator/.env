# =============================================================================
# ORCHESTRATOR SERVICE CONFIGURATION
# =============================================================================
# This is the main .env file for the orchestrator service
# It manages all LLM agents, IRCoT, Graph Reasoning, and service connections
# =============================================================================
USE_LANGGRAPH=true
# -----------------------------------------------------------------------------
# 1. OPENROUTER API (Primary LLM Provider)
# -----------------------------------------------------------------------------
# All LLM calls go through OpenRouter - https://openrouter.ai
OPENROUTER_API_KEY=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
OPENAI_API_KEY=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
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT=60
OPENROUTER_MAX_RETRIES=3

# --------------------------------------------------------------------------
# 2. NEO4J GRAPH DATABASE
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=uitchatbot
NEO4J_DATABASE=neo4j

# -----------------------------------------------------------------------------
# 3. RAG SERVICE CONNECTION
# -----------------------------------------------------------------------------
RAG_SERVICE_URL=http://localhost:8000
RAG_SERVICE_TIMEOUT=60
RAG_SERVICE_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# 4. IRCOT CONFIGURATION (Chain-of-Thought Reasoning)
# -----------------------------------------------------------------------------
IRCOT_ENABLED=true
IRCOT_MODE=automatic
IRCOT_MAX_ITERATIONS=2
IRCOT_COMPLEXITY_THRESHOLD=6.5
IRCOT_MIN_CONFIDENCE=0.6

# -----------------------------------------------------------------------------
# 5. GRAPH REASONING
# -----------------------------------------------------------------------------
ENABLE_GRAPH_REASONING=true

# -----------------------------------------------------------------------------
# 6. SERVER CONFIGURATION
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# 7. AGENT CONFIGURATION
# -----------------------------------------------------------------------------
ENABLE_VERIFICATION=false
ENABLE_PLANNING=true

# Default System Prompt
DEFAULT_SYSTEM_PROMPT=Bạn là trợ lý AI thông minh của Chatbot-UIT. Hãy trả lời chính xác và hữu ích bằng tiếng Việt.
